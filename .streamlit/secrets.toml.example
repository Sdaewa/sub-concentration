# Copy to secrets.toml for local dev (never commit secrets.toml).
# On Streamlit Community Cloud: paste into App settings → Secrets.

# Neon / Postgres (recommended for Streamlit Cloud). If set, SQLite path options are ignored.
# DATABASE_URL = "postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require"

# Optional: SQLite file path when DATABASE_URL is not set. Default: ./data/observatory.db
# DB_PATH = "/tmp/observatory.db"
